      "password": "SecurePass@123",
      "expectedResult": "Input sanitized, no DB damage"
    },
    {
      "testId": "TC_REG_010",
      "scenario": "XSS in Name Field",
      "category": "security",
      "fullName": "<script>alert('XSS')</script>",
